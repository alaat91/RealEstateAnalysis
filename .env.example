APP_NAME="Real Estate Analysis API"
ENVIRONMENT="local"
DEBUG=true
API_V1_PREFIX="/api/v1"

# Local docker-compose database
DATABASE_URL="postgresql+psycopg://postgres:postgres@db:5432/realestate"

# Use a strong value in production
SECRET_KEY="change-me-in-production"

# CORS origins separated by commas. Add your Vue dev server here.
BACKEND_CORS_ORIGINS='["http://localhost:5173","http://localhost:3000"]'